<div class="section-background color-{{ section.settings.color_scheme }}"></div>
<div
  class="section section--page-width breadcrumbs--{{ section.id }} color-{{ section.settings.color_scheme }}"
>
  <div
    class="breadcrumbs__wrapper spacing-style"
    style="{% render 'spacing-style', settings: section.settings %}"
  >
    {%- render 'breadcrumbs' %}
  </div>
</div>

{% schema %}
{
  "name": "t:names.breadcrumbs",
  "class": "section-breadcrumbs",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "t:settings.color_scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "t:content.padding"
    },
    {
      "type": "range",
      "id": "padding-block-start",
      "label": "t:settings.top",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding-block-end",
      "label": "t:settings.bottom",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "checkbox",
      "id": "enable_mobile_padding",
      "label": "t:settings.enable_mobile_padding",
      "default": false
    },
    {
      "type": "range",
      "id": "padding-block-start-mobile",
      "label": "t:settings.padding_top_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.enable_mobile_padding }}"
    },
    {
      "type": "range",
      "id": "padding-block-end-mobile",
      "label": "t:settings.padding_bottom_mobile",
      "min": 0,
      "max": 100,
      "step": 1,
      "unit": "px",
      "default": 0,
      "visible_if": "{{ section.settings.enable_mobile_padding }}"
    }
  ],
  "presets": [
    {
      "name": "t:names.breadcrumbs"
    }
  ]
}
{% endschema %}
